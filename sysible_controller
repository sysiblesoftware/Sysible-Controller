#!/bin/bash
# Sysible Controller control CLI - installed to /usr/local/bin/sysible_controller
# by install_sysible.sh. The backend API runs as a real systemd service (sysible-backend) so
# it survives reboots and isn't tied to a terminal session or a
# script's own lifetime. This wraps `systemctl` for that service and
# separately manages the desktop GUI client, which still has no
# business being a systemd service - it's one human's desktop app,
# not a daemon.
#
# Usage: sysible_controller {start|stop|restart|status|logs|gui|destroy}

BASE="/opt/sysible"
VENV="$BASE/venv"
RUN_DIR="$BASE/run"
CLIENT_PID_FILE="$RUN_DIR/client.pid"
# Per-user fallback for the client pid/log, used when the shared run dir or a
# stale root-owned file there isn't writable by the desktop user. Kept in a
# fixed place (not a random temp name) so a later 'status'/'stop' invocation -
# even a different process - can still find it. See _resolve_gui_log / _start_gui.
PID_FALLBACK="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/sysible-client.pid"
PORTAL_PID_FILE="$RUN_DIR/portal.pid"
GUI_LOG_FILE="$RUN_DIR/gui.log"
SERVICE="sysible-backend"
PORT=9000
CERT_FILE="$BASE/certs/server.crt"
DESKTOP_FILE="/usr/share/applications/sysible-controller.desktop"

# Best-effort fallback only - install_sysible.sh already creates this
# with permissive (1777) mode so both root and the desktop user can
# write client.pid/gui.log into it; this mkdir mostly matters for an
# install predating that change.
mkdir -p "$RUN_DIR" 2>/dev/null

_require_root() {
  if [[ $EUID -ne 0 ]]; then
    echo "Run as root: sudo sysible_controller $1"
    exit 1
  fi
}

# The pid file actually in use: the shared run-dir one if present, else the
# per-user fallback (written when the run dir wasn't writable at start).
_effective_pid_file() {
  if [[ -f "$CLIENT_PID_FILE" ]]; then
    echo "$CLIENT_PID_FILE"
  elif [[ -f "$PID_FALLBACK" ]]; then
    echo "$PID_FALLBACK"
  else
    echo "$CLIENT_PID_FILE"
  fi
}

_client_running() {
  local f; f="$(_effective_pid_file)"
  [[ -f "$f" ]] && kill -0 "$(cat "$f")" 2>/dev/null
}

# =========================================================
# The GUI process itself doesn't actually need to run as root - the
# only thing under /opt/sysible it reads locally is the admin API key
# (client/api.py's _API_KEY_FILE, mode 600 root-only by design - see
# install_sysible.sh's "PROVISION THE ADMIN API KEY"), and that same
# api.py checks the SYSIBLE_API_KEY env var *before* ever touching the
# file. So elevate just this one instant, display-free `cat` instead
# of the whole long-running Qt process.
#
# Running the entire GUI under pkexec (the previous approach) is what
# was actually breaking the application-menu launcher: a pkexec'd
# process's environment is reset, so it loses the very things Qt needs
# to draw a window on the desktop's existing session (DISPLAY/
# XAUTHORITY, and pkexec never forwards Wayland's WAYLAND_DISPLAY/
# XDG_RUNTIME_DIR at all) - the auth prompt itself comes from polkit's
# own always-running agent, not from the elevated process, so it pops
# up fine right up until the *actual app* fails to ever connect to the
# display. `cat` has no display to connect to, so none of that applies
# here.
# =========================================================
_fetch_api_key() {
  if [[ -n "$SYSIBLE_API_KEY" ]]; then
    return
  fi

  if [[ $EUID -eq 0 ]]; then
    SYSIBLE_API_KEY="$(cat "$BASE/api_key.txt" 2>/dev/null)"
  elif command -v pkexec >/dev/null 2>&1; then
    SYSIBLE_API_KEY="$(pkexec cat "$BASE/api_key.txt" 2>/dev/null)"
  else
    echo "Run as root, or install pkexec, to read $BASE/api_key.txt: sudo sysible_controller gui"
    exit 1
  fi

  if [[ -z "$SYSIBLE_API_KEY" ]]; then
    echo "ERROR: could not read the admin API key ($BASE/api_key.txt) - was the password prompt cancelled?" | tee -a "$GUI_LOG_FILE" >&2
    exit 1
  fi

  export SYSIBLE_API_KEY
}

# Pick a log path we can actually write to. The shared run dir is created
# 1777 at install so any user can drop a file there, but two things still
# break a plain redirect: a stale gui.log left root-owned (mode 644) by an
# earlier `sudo` run can't be truncated by the desktop user, and an install
# predating the 1777 change has a non-writable run dir. In either case fall
# back to a per-user location instead of dying with "Permission denied".
_resolve_gui_log() {
  # ( : > FILE ) truncates/creates FILE if writable, else fails quietly.
  if ( : > "$GUI_LOG_FILE" ) 2>/dev/null; then
    chmod 666 "$GUI_LOG_FILE" 2>/dev/null
    return
  fi
  local base="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}"
  GUI_LOG_FILE="$base/sysible-gui.log"
  : > "$GUI_LOG_FILE" 2>/dev/null
  echo "Note: $RUN_DIR/gui.log isn't writable as this user; logging GUI output to $GUI_LOG_FILE instead." >&2
}

_start_gui() {
  if _client_running; then
    pid="$(cat "$(_effective_pid_file)")"
    echo "GUI client already running (PID $pid) - signaling it to bring its window to the front..."
    # A closed/hidden GUI process used to be a dead end here - this just
    # printed "already running" and returned, leaving no way back short of
    # `sysible_controller stop` + `start` any time the tray icon wasn't
    # available, or was available per Qt but not actually rendered by the
    # desktop (common on several Linux desktop environments). SIGUSR1 tells
    # the already-running process to show/raise/activate its window instead
    # - see client/main.py's MainWindow._on_sigusr1 - regardless of tray
    # state.
    kill -USR1 "$pid" 2>/dev/null
    return
  fi

  _fetch_api_key
  _resolve_gui_log

  echo "Starting GUI client..."
  cd "$BASE" || exit 1
  source "$VENV/bin/activate"
  export PYTHONPATH="$BASE"

  # setsid + redirected stdio detaches the GUI from this script's own
  # session before it returns, so it isn't tied to this process's
  # lifetime regardless of how it was launched.
  setsid python3 client/main.py </dev/null >"$GUI_LOG_FILE" 2>&1 &
  disown
  GUI_PID=$!
  # Same writability story as the log: fall back to the per-user pid file if
  # the shared one isn't writable, so 'status'/'stop' still find it (they
  # resolve the same fallback via _effective_pid_file). Clear any stale
  # fallback first so it can't shadow a successful shared write later.
  rm -f "$PID_FALLBACK" 2>/dev/null
  if ! ( echo "$GUI_PID" > "$CLIENT_PID_FILE" ) 2>/dev/null; then
    CLIENT_PID_FILE="$PID_FALLBACK"
    echo "$GUI_PID" > "$CLIENT_PID_FILE"
  fi

  # $RUN_DIR is shared between however this got invoked - root via
  # `sudo sysible_controller start`, or the desktop user directly via
  # the application menu icon - so a later run by a *different* user
  # needs to be able to overwrite these, not just whoever wrote them
  # first. Loosening their own mode (not the directory) is enough;
  # install_sysible.sh already makes $RUN_DIR itself 1777 so anyone can
  # create a file there in the first place.
  chmod 666 "$CLIENT_PID_FILE" "$GUI_LOG_FILE" 2>/dev/null

  echo "GUI client PID: $GUI_PID"
}

_stop_gui() {
  local f; f="$(_effective_pid_file)"
  if _client_running; then
    pid="$(cat "$f")"
    echo "Stopping GUI client (PID $pid)..."
    kill "$pid" 2>/dev/null
  fi
  # Remove both the shared and the per-user pid file so neither lingers.
  rm -f "$CLIENT_PID_FILE" "$PID_FALLBACK"
}

# =========================================================
# WEB CONSOLE (browser-based, headless-friendly GUI)
# Managed by backend/webgui_manager.py - which handles building the front
# end, the persistent cookie secret, TLS (reusing the controller's own
# cert), health-gated startup, and stop. We drive it from the same venv the
# backend uses so it can import the controller's client.* modules. This is
# what gives a headless controller a GUI: a browser, not a desktop app.
# Best-effort: a web-console hiccup never blocks the controller itself.
# Set SYSIBLE_WEBGUI=0 to opt out of auto-start.
# =========================================================
# The web console runs as its own systemd service (sysible-webgui), separate
# from the backend and the desktop GUI, so it can be started/stopped on its own.
WEBGUI_SERVICE="sysible-webgui"

_start_webgui() {
  if ! systemctl list-unit-files "${WEBGUI_SERVICE}.service" >/dev/null 2>&1 \
     || ! systemctl cat "${WEBGUI_SERVICE}.service" >/dev/null 2>&1; then
    echo "Web console service not installed. Run 'sudo $BASE/install_sysible.sh' first."
    return 1
  fi
  echo "Starting web console (${WEBGUI_SERVICE})..."
  systemctl enable --now "${WEBGUI_SERVICE}.service" 2>/dev/null
  local ip; ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
  echo "  Web console: https://${ip:-<this-host>}:8800/"
}

_stop_webgui() {
  systemctl disable --now "${WEBGUI_SERVICE}.service" >/dev/null 2>&1 || true
}

# =========================================================
# Readiness wait + "is this actually current code" self-check -
# needed since systemd reporting the unit as "active" only means the
# process launched, not that uvicorn finished binding and serving
# current routes yet.
# =========================================================
_wait_for_backend() {
  echo "Waiting for API..."

  until curl -s --cacert "$CERT_FILE" "https://127.0.0.1:$PORT/" >/dev/null 2>&1; do
    if ! systemctl is-active --quiet "$SERVICE"; then
      echo "ERROR: $SERVICE failed to start. Check: journalctl -u $SERVICE -n 50"
      exit 1
    fi
    sleep 1
  done

  if ! curl -s --cacert "$CERT_FILE" "https://127.0.0.1:$PORT/openapi.json" | grep -q '"/agents/heartbeat"'; then
    echo "ERROR: API is responding but doesn't expose the expected routes (or the TLS cert doesn't match) - likely stale code or a bad cert."
    echo "Run 'sudo lsof -i :$PORT' to see what's actually serving this port."
    exit 1
  fi

  echo "API ready (current code confirmed, HTTPS verified)"
}

cmd_start() {
  _require_root start

  if [[ ! -f "$CERT_FILE" ]]; then
    echo "ERROR: TLS certificate not found at $CERT_FILE"
    echo "Run 'sudo $BASE/install_sysible.sh' first."
    exit 1
  fi

  echo "Starting $SERVICE..."
  systemctl start "$SERVICE"
  _wait_for_backend

  echo ""
  echo "Controller backend is running. The web console and desktop GUI are"
  echo "separate services, started on their own:"
  echo "   Web console : sudo sysible_controller webgui start"
  echo "   Desktop GUI : sysible_controller gui"
  echo "'sysible_controller status' to check, 'sysible_controller logs' to tail the backend."
}

cmd_stop() {
  _require_root stop

  _stop_webgui
  _stop_gui

  echo "Stopping $SERVICE..."
  systemctl stop "$SERVICE" 2>/dev/null

  # Safety net for a portal subprocess left outside the unit's cgroup
  # (or anything else squatting on $PORT) - a backend process doesn't
  # always clean up everything it spawned on its own.
  if [[ -f "$PORTAL_PID_FILE" ]]; then
    pid="$(cat "$PORTAL_PID_FILE")"
    if kill -0 "$pid" 2>/dev/null; then
      echo "Stopping portal (PID $pid)..."
      kill "$pid" 2>/dev/null
    fi
    rm -f "$PORTAL_PID_FILE"
  fi

  if command -v lsof >/dev/null 2>&1; then
    STRAY_PIDS="$(lsof -ti tcp:"$PORT" 2>/dev/null)"
    if [[ -n "$STRAY_PIDS" ]]; then
      echo "Port $PORT still held by PID(s) $STRAY_PIDS (untracked) - killing..."
      kill $STRAY_PIDS 2>/dev/null
      sleep 1
      STRAY_PIDS="$(lsof -ti tcp:"$PORT" 2>/dev/null)"
      [[ -n "$STRAY_PIDS" ]] && kill -9 $STRAY_PIDS 2>/dev/null
    fi
  fi

  echo "Done."
}

cmd_restart() {
  _require_root restart
  cmd_stop
  cmd_start
}

cmd_status() {
  systemctl status "$SERVICE" --no-pager
  echo ""
  if _client_running; then
    echo "GUI client: running (PID $(cat "$(_effective_pid_file)"))"
  else
    echo "GUI client: not running (see $GUI_LOG_FILE for the last launch attempt's output, if any)"
  fi
  "$VENV/bin/python" - "$BASE" 2>/dev/null <<'PY' || true
import sys
sys.path.insert(0, sys.argv[1])
from backend import webgui_manager as m
s = m.status()
if s.get("running"):
    print(f"Web console: running ({s.get('scheme')} port {s.get('port')}, PID {s.get('pid')})")
else:
    print("Web console: not running")
PY
}

cmd_logs() {
  journalctl -u "$SERVICE" -f
}

cmd_gui() {
  # No _require_root here anymore - see _fetch_api_key for why the GUI
  # itself doesn't need to run as root, just a one-shot privileged read.
  _start_gui
}

cmd_webgui() {
  # Manual control of the browser-based console, independent of the
  # controller's own start/stop. Root: it reads the TLS key and writes its
  # pid/secret under $RUN_DIR, same as the backend.
  case "$2" in
    start)
      _require_root "webgui start"
      _start_webgui
      ;;
    stop)
      _require_root "webgui stop"
      _stop_webgui
      echo "Web console stopped."
      ;;
    status|"")
      if systemctl is-active --quiet "${WEBGUI_SERVICE}.service"; then
        ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
        echo "Web console: running (${WEBGUI_SERVICE}) -> https://${ip:-<this-host>}:8800/"
      else
        echo "Web console: not running. Start it with 'sysible_controller webgui start'."
      fi
      systemctl status "${WEBGUI_SERVICE}.service" --no-pager 2>/dev/null | head -5 || true
      ;;
    logs)
      journalctl -u "${WEBGUI_SERVICE}.service" -n 50 --no-pager
      ;;
    *)
      echo "Usage: sysible_controller webgui {start|stop|status|logs}"
      exit 1
      ;;
  esac
}

cmd_destroy() {
  _require_root destroy

  echo "==================================================================="
  echo " THIS WILL PERMANENTLY REMOVE SYSIBLE FROM THIS MACHINE:"
  echo "   - stop and disable the $SERVICE systemd service"
  echo "   - delete $BASE (database, TLS certificate, admin API key -"
  echo "     everything)"
  echo "   - remove this 'sysible_controller' command"
  echo ""
  echo " Enrolled hosts' agents are NOT touched by this - their own"
  echo " sysible-agent systemd services keep running and will just start"
  echo " failing to reach this controller. Disenroll hosts first (or run"
  echo " disenroll_agent.sh on each one) if you want them cleaned up too."
  echo "==================================================================="
  echo ""

  read -rp "Type 'destroy' to confirm: " confirm
  if [[ "$confirm" != "destroy" ]]; then
    echo "Aborted - nothing was changed."
    exit 1
  fi

  echo "Stopping everything..."
  cmd_stop

  echo "Disabling and removing $SERVICE..."
  systemctl disable --now "$SERVICE" 2>/dev/null
  systemctl disable --now "${WEBGUI_SERVICE}.service" 2>/dev/null
  rm -f "/etc/systemd/system/$SERVICE.service" "/etc/systemd/system/${WEBGUI_SERVICE}.service"
  systemctl daemon-reload

  DB_FILE="$BASE/backend/sysible.db"
  if [[ -f "$DB_FILE" ]]; then
    BACKUP="/tmp/sysible-backup-$(date +%Y%m%d%H%M%S).db"
    cp -f "$DB_FILE" "$BACKUP" 2>/dev/null && echo "Database backed up to $BACKUP (this copy is left behind on purpose - delete it yourself once you're sure you don't need it)."
  fi

  echo "Removing $BASE..."
  rm -rf "$BASE"

  # $BASE covers everything installed under it, but the application
  # menu launcher lives outside $BASE in the system-wide applications
  # directory, so it needs its own cleanup - otherwise the icon tile
  # stays in the applications menu/dock pointing at a launcher that no
  # longer works.
  if [[ -f "$DESKTOP_FILE" ]]; then
    echo "Removing application menu launcher..."
    rm -f "$DESKTOP_FILE"
    command -v update-desktop-database >/dev/null 2>&1 && \
      update-desktop-database "$(dirname "$DESKTOP_FILE")" >/dev/null 2>&1
  fi

  # =========================================================
  # UNPIN FROM GNOME-FAMILY DOCKS/TASKBARS (best-effort)
  # Deleting $DESKTOP_FILE above removes the entry from the
  # applications menu/grid, but a dock/taskbar *pin* ("Add to
  # Favorites") is stored separately, per-user, in dconf - it
  # references the launcher by filename and survives the file being
  # deleted (showing up as a broken/generic icon instead of just
  # disappearing). This only covers desktops that use the GNOME
  # favorite-apps key (GNOME, Ubuntu's default, Cinnamon) via
  # gsettings, run as the actual desktop user (not root) since it's
  # their per-user setting, not root's. KDE Plasma and XFCE store
  # panel/taskbar pins in their own config files instead and aren't
  # covered here - unpin the icon manually on those (right-click it
  # -> Unpin/Remove from panel) if it's pinned.
  # =========================================================
  REAL_USER="${SUDO_USER:-$(logname 2>/dev/null)}"
  if [[ -n "$REAL_USER" ]] && command -v gsettings >/dev/null 2>&1; then
    REAL_UID="$(id -u "$REAL_USER" 2>/dev/null)"
    if [[ -n "$REAL_UID" ]]; then
      for SCHEMA in org.gnome.shell org.cinnamon; do
        CURRENT="$(sudo -u "$REAL_USER" \
          DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$REAL_UID/bus" \
          gsettings get "$SCHEMA" favorite-apps 2>/dev/null)"

        if [[ "$CURRENT" == *"sysible-controller.desktop"* ]]; then
          echo "Unpinning from $SCHEMA dock/favorites..."
          UPDATED="$(python3 -c "
import ast, sys
try:
    apps = ast.literal_eval(sys.argv[1])
except Exception:
    sys.exit(1)
print([a for a in apps if a != 'sysible-controller.desktop'])
" "$CURRENT" 2>/dev/null)"

          if [[ -n "$UPDATED" ]]; then
            sudo -u "$REAL_USER" \
              DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$REAL_UID/bus" \
              gsettings set "$SCHEMA" favorite-apps "$UPDATED" 2>/dev/null
          fi
        fi
      done
    fi
  fi

  echo "Sysible Controller has been removed from this machine."
  echo "Removing this command..."
  rm -f "$0"
}

case "$1" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  logs)    cmd_logs ;;
  gui)     cmd_gui ;;
  webgui)  cmd_webgui "$@" ;;
  destroy) cmd_destroy ;;
  *)
    echo "Usage: sysible_controller {start|stop|restart|status|logs|gui|webgui|destroy}"
    exit 1
    ;;
esac
